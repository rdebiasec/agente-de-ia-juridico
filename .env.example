# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Slack (revisión humana / HITL del abogado)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_REVIEW_CHANNEL=#revision-abogado

# Twilio SMS — alertas de plazos al móvil del abogado (transaccional)
# Recomendado: Messaging Service en producción (compliance + sender pool).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=
TWILIO_ALERT_TO=
TWILIO_STATUS_CALLBACK=

# Persistencia (Fase B)
# Local (Postgres+pgvector vía Docker): levante `docker compose -f deploy/docker-compose.yml up -d db`
# y use esta URL cuando corre la app en la Mac (no dentro del contenedor app):
DATABASE_URL=postgresql+psycopg://agente:agente@localhost:5432/agente
# Vacío => repositorio en memoria (solo tests rápidos sin Docker).
# DATABASE_URL=
# Render/prod: render.yaml inyecta DATABASE_URL desde la base agente-db (no hace falta en .env de prod).

# App
PORT=8000
REDIS_URL=redis://localhost:6379/0

# Acceso web — generar secretos fuertes (nunca usar los placeholders de abajo en prod)
SITE_USERNAME=despacho
SITE_PASSWORD=genera-un-secreto-local-min-12-chars
SESSION_SECRET=genera-un-secreto-aleatorio-min-32-chars
SESSION_IDLE_MINUTES=360
SESSION_MAX_MESSAGES=120
AGENT_MAX_TURNS=25
SESSION_COOKIE_SECURE=false
# Desarrollo local: omitir login manual (nunca activar en producción / Render).
DEV_AUTO_LOGIN=true
# Telemetría de depuración (middleware /debug/*). Mantener false en Render.
APP_DEBUG=false
